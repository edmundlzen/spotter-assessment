# Local development only. Render supplies these values through its environment.
SECRET_KEY=
DEBUG=False

# Bare hostnames only (no scheme or path), comma-separated.
ALLOWED_HOSTS=localhost,127.0.0.1
RENDER_EXTERNAL_HOSTNAME=

# Full http(s) origins, comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional for local development. SQLite is used when this is empty.
DATABASE_URL=

# Server-only OpenRouteService configuration. Obtain the key from
# https://openrouteservice.org/ and never expose it through a VITE_ variable.
ORS_API_KEY=
ORS_CONNECT_TIMEOUT_SECONDS=3.05
ORS_READ_TIMEOUT_SECONDS=15
ORS_MAX_RETRIES=1
