# Local development only. Render supplies these values through its environment.
SECRET_KEY=
DEBUG=False

# Bare hostnames only (no scheme or path), comma-separated.
ALLOWED_HOSTS=localhost,127.0.0.1
RENDER_EXTERNAL_HOSTNAME=

# Full http(s) origins, comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional in Phase 2. SQLite is used when this is empty.
DATABASE_URL=
